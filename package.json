{
  "name": "scoobertdoobert-pizza",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "scoobertdoobert.pizza — a haunted electronic pizza storefront that falls backward through web eras into a low-poly PS1 world.",
  "scripts": {
    "dev": "vite",
    "build": "vite-react-ssg build",
    "postbuild": "node scripts/check-build.mjs",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "shoot": "node scripts/shoot.mjs",
    "shoot:world": "node scripts/shoot-world.mjs",
    "shoot:descent": "node scripts/shoot-descent.mjs",
    "shoot:fallback": "node scripts/shoot-fallback.mjs",
    "shoot:rooms": "node scripts/shoot-rooms.mjs",
    "shoot:levels": "node scripts/shoot-levels.mjs",
    "shoot:ballpit": "node scripts/shoot-ballpit.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@vercel/blob": "^2.4.1",
    "98.css": "^0.1.21",
    "leva": "^0.9.36",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "three": "^0.169.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.7.0",
    "playwright": "^1.56.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-react-ssg": "^0.9.1-beta.1"
  }
}
